---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  url?: string;
}

const {
  title = 'Verttex — Agencia de Software y Marketing Digital',
  description = 'Creamos páginas web, sistemas personalizados, automatizaciones, agentes de IA y estrategias de marketing digital para hacer crecer tu empresa.',
  image = '/og-image.jpeg',
  url = 'https://verttexagencia.com',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, url);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/logo.png" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="agencia de software, marketing digital, desarrollo web, sistemas personalizados, automatizaciones, agentes de IA, aplicaciones móviles, redes sociales, Rosario, Argentina" />
    <meta name="author" content="Verttex" />
    <meta name="robots" content="index, follow" />

    <!-- Open Graph (Facebook, LinkedIn, WhatsApp) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, url)} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Verttex" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(image, url)} />

    <!-- Schema.org structured data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Verttex",
        "description": "Agencia de software y marketing digital en Rosario, Argentina. Desarrollo web, sistemas personalizados, automatizaciones, agentes de IA y gestión de redes sociales.",
        "url": "https://verttexagencia.com",
        "logo": "https://verttexagencia.com/logo.jpeg",
        "image": "https://verttexagencia.com/og-image.jpeg",
        "address": {
          "@type": "PostalAddress",
          "streetAddress": "Bv. España 2781",
          "addressLocality": "Rosario",
          "addressRegion": "Santa Fe",
          "addressCountry": "AR"
        },
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer service",
          "availableLanguage": "Spanish"
        },
        "areaServed": ["AR", "UY", "CL", "MX", "ES"],
        "serviceType": [
          "Desarrollo Web",
          "Sistemas Personalizados",
          "Automatizaciones",
          "Agentes de Inteligencia Artificial",
          "Aplicaciones Móviles",
          "Marketing Digital",
          "Gestión de Redes Sociales",
          "Producción de Video",
          "Producción de Contenido"
        ],
        "sameAs": [
          "https://www.instagram.com/verttexagencia"
        ]
      }
    </script>
  </head>
  <body class="bg-zinc-950 text-white antialiased">
    <slot />
  </body>
</html>
