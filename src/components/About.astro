---
const stats = [
  { value: "+12", label: "Proyectos entregados" },
  { value: "+10", label: "Clientes activos"     },
  { value: "+5",  label: "Países en los que operamos" },
];

const clients = [
  { name: "Cliente 1", src: "/empresa1.jpeg" },
  { name: "Cliente 2", src: "/empresa2.png"  },
  { name: "Cliente 3", src: "/empresa3.png"  },
  { name: "Cliente 4", src: "/empresa4.webp" },
  { name: "Cliente 5", src: "/empresa5.png"  },
  { name: "Cliente 6", src: "/empresa6.webp" },
];
---

<section id="nosotros" class="bg-[#17120C] py-28 px-8 md:px-16 overflow-hidden">
  <div class="max-w-6xl mx-auto">

    <!-- Badge -->
    <div class="mb-12">
      <span class="inline-flex items-center border border-[#B8864E]/40 text-[#B8864E] text-xs font-medium px-4 py-1.5 rounded-full tracking-wide">
        Nosotros
      </span>
    </div>

    <!-- Manifiesto + Stats -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">

      <!-- Manifiesto -->
      <div>
        <h2 class="text-4xl md:text-5xl font-bold text-white leading-tight mb-6">
          No vendemos tecnología.<br />
          <span class="italic font-light text-white/40">Vendemos resultados.</span>
        </h2>
        <p class="text-white/50 text-base leading-relaxed max-w-md">
          Somos un equipo joven con obsesión por los detalles. Cada proyecto lo tomamos como si fuera el nuestro — porque creemos que cuando tu empresa crece, nosotros crecemos con vos.
        </p>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-3 gap-6">
        {stats.map((s) => (
          <div class="flex flex-col gap-2 border-l border-[#B8864E]/25 pl-6">
            <span class="text-4xl md:text-5xl font-bold text-white leading-none">{s.value}</span>
            <span class="text-white/40 text-xs leading-snug">{s.label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- CTA -->
    <div class="border-t border-white/[0.06] pt-12 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <p class="text-white/50 text-sm max-w-sm leading-relaxed">
        ¿Querés que trabajemos juntos? Contanos tu proyecto y te respondemos en menos de 24 horas.
      </p>
      <a
        href="#contacto"
        class="flex-shrink-0 bg-[#B8864E] hover:bg-[#D4A574] text-black font-semibold text-sm px-7 py-3 rounded-full transition-all duration-300 shadow-lg shadow-[#B8864E]/20"
      >
        Empezar ahora →
      </a>
    </div>

  </div>

</section>
