---
const year = new Date().getFullYear();

const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Proceso',  href: '#proceso'   },
  { label: 'Contacto', href: '#contacto'  },
];

const services = [
  'Desarrollo Web',
  'Sistemas Personalizados',
  'Automatizaciones',
  'Agentes de IA',
  'Apps Móviles',
  'Redes Sociales',
  'Producción de Video',
];
---

<footer class="bg-[#0D0F12] border-t border-white/[0.07] pt-16 pb-8 px-8 md:px-16">
  <div class="max-w-6xl mx-auto">

    <!-- Grid principal -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 pb-12 border-b border-white/[0.07]">

      <!-- Columna 1: Brand -->
      <div class="flex flex-col gap-5">
        <a href="#" class="text-white font-bold text-2xl tracking-widest uppercase hover:text-white/80 transition-colors duration-200">Verttex</a>
        <p class="text-white/50 text-sm leading-relaxed max-w-xs">
          Transformamos ideas en productos digitales que generan resultados reales.
        </p>
        <!-- Instagram -->
        <a
          href="https://instagram.com/verttex.uy"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 text-white/50 hover:text-[#D4A574] transition-colors duration-200 w-fit"
          aria-label="Instagram de Verttex"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
          </svg>
          <span class="text-sm">@verttex.uy</span>
        </a>
        <!-- WhatsApp -->
        <a
          href="https://wa.me/598096697977"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2.5 text-white/50 hover:text-[#D4A574] transition-colors duration-200 w-fit"
          aria-label="WhatsApp de Verttex"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>
          </svg>
          <span class="text-sm">096 697 977</span>
        </a>
        <!-- Email -->
        <a
          href="mailto:contacto@verttex.net"
          class="flex items-center gap-2.5 text-white/50 hover:text-[#D4A574] transition-colors duration-200 w-fit"
          aria-label="Email de Verttex"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <span class="text-sm">contacto@verttex.net</span>
        </a>
      </div>

      <!-- Columna 2: Navegación -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white/30 text-xs font-semibold tracking-widest uppercase">Navegación</h3>
        <ul class="flex flex-col gap-3">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-white/60 hover:text-white text-sm transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Columna 3: Servicios -->
      <div class="flex flex-col gap-4">
        <h3 class="text-white/30 text-xs font-semibold tracking-widest uppercase">Servicios</h3>
        <ul class="flex flex-col gap-3">
          {services.map((service) => (
            <li>
              <a
                href="#servicios"
                class="text-white/60 hover:text-white text-sm transition-colors duration-200"
              >
                {service}
              </a>
            </li>
          ))}
        </ul>
      </div>

    </div>

    <!-- Barra inferior -->
    <div class="pt-8 flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-white/30 text-xs">
        © {year} Verttex. Todos los derechos reservados.
      </p>
      <p class="text-white/20 text-xs">
        Hecho con ♥ en Rosario, Argentina
      </p>
    </div>

  </div>
</footer>
