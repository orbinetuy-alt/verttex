---
type IconKey = 'globe' | 'sparkles' | 'layers' | 'zap' | 'smartphone' | 'share' | 'video' | 'radio';

const icons: Record<IconKey, string> = {
  globe: `<circle cx="12" cy="12" r="10"/><line x1="2" x2="22" y1="12" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>`,
  sparkles: `<path d="M9.937 15.5A2 2 0 0 0 8.5 14.063l-6.135-1.582a.5.5 0 0 1 0-.962L8.5 9.936A2 2 0 0 0 9.937 8.5l1.582-6.135a.5.5 0 0 1 .963 0L14.063 8.5A2 2 0 0 0 15.5 9.937l6.135 1.581a.5.5 0 0 1 0 .964L15.5 14.063a2 2 0 0 0-1.437 1.437l-1.582 6.135a.5.5 0 0 1-.963 0z"/><path d="M20 3v4"/><path d="M22 5h-4"/><path d="M4 17v2"/><path d="M5 18H3"/>`,
  layers: `<path d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>`,
  zap: `<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>`,
  smartphone: `<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>`,
  share: `<circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"/><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"/>`,
  video: `<path d="m22 8-6 4 6 4V8z"/><rect width="14" height="12" x="2" y="6" rx="2" ry="2"/>`,
  radio: `<path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.4"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.4"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/>`,
};

interface Service {
  title: string;
  label: string;
  icon: IconKey;
  featured?: boolean;
}

const softwareServices: Service[] = [
  { title: "Páginas Web",          label: "Sitios modernos y rápidos que convierten visitas en clientes.",       icon: "globe"       },
  { title: "Agentes de IA",        label: "Automatizá la atención y procesos con inteligencia artificial.",      icon: "sparkles", featured: true },
  { title: "Sistemas a Medida",    label: "Gestión, stock, reservas — tecnología propia para tu negocio.",       icon: "layers"      },
  { title: "Automatizaciones",     label: "Eliminá tareas repetitivas con flujos automáticos inteligentes.",     icon: "zap"         },
  { title: "Apps Móviles",         label: "Aplicaciones iOS y Android conectadas a tus sistemas.",               icon: "smartphone"  },
];

const marketingServices: Service[] = [
  { title: "Manejo de Redes",       label: "Contenido, comunidad y crecimiento en todas las plataformas.",       icon: "share" },
  { title: "Creación de Videos",    label: "Producción audiovisual profesional para redes y campañas.",          icon: "video" },
  { title: "Producción de Contenido", label: "Programas y formatos que posicionan tu marca como referente.",    icon: "radio" },
];
---

<section id="servicios" class="bg-[#1C1F24] py-28 px-8 md:px-16">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="text-center mb-20">
      <span class="inline-flex items-center border border-[#B8864E]/40 text-[#B8864E] text-xs font-medium px-4 py-1.5 rounded-full mb-8 tracking-wide">
        Nuestros Servicios
      </span>
      <h2 class="text-4xl md:text-6xl font-bold text-white leading-tight">
        Todo lo que tu empresa<br />
        <span class="italic font-light text-white/40">necesita para crecer</span>
      </h2>
    </div>

    <!-- Software -->
    <p class="text-center text-[#B8864E] text-xs font-semibold uppercase tracking-[0.25em] mb-10">Software</p>
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 mb-6">
      {softwareServices.map((s) => (
        <div class:list={[
          "group flex flex-col items-center text-center gap-5 rounded-2xl p-8 transition-all duration-300 cursor-default",
          s.featured
            ? "bg-[#B8864E]/[0.09] border border-[#B8864E]/30 hover:border-[#B8864E]/60 hover:bg-[#B8864E]/[0.14]"
            : "bg-[#16181D] border border-white/[0.06] hover:border-[#B8864E]/20 hover:bg-[#1A1D22]",
        ]}>
          <!-- Icon halo -->
          <div class:list={[
            "w-16 h-16 rounded-2xl flex items-center justify-center transition-all duration-300",
            s.featured
              ? "bg-[#B8864E]/15 group-hover:bg-[#B8864E]/25"
              : "bg-[#B8864E]/08 group-hover:bg-[#B8864E]/15",
          ]}>
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#B8864E"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons[s.icon]}
            />
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm mb-1.5 leading-snug">{s.title}</h3>
            <p class="text-white/40 text-xs leading-relaxed">{s.label}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Divider -->
    <div class="flex items-center gap-6 my-12">
      <div class="flex-1 h-px bg-white/[0.06]"></div>
      <span class="text-white/20 text-xs uppercase tracking-widest">Marketing Digital</span>
      <div class="flex-1 h-px bg-white/[0.06]"></div>
    </div>

    <!-- Marketing -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 max-w-3xl mx-auto">
      {marketingServices.map((s) => (
        <div class="group flex flex-col items-center text-center gap-5 bg-[#16181D] border border-white/[0.06] hover:border-[#B8864E]/20 hover:bg-[#1A1D22] rounded-2xl p-8 transition-all duration-300 cursor-default">
          <div class="w-16 h-16 rounded-2xl bg-[#B8864E]/08 group-hover:bg-[#B8864E]/15 flex items-center justify-center transition-all duration-300">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="none"
              stroke="#B8864E"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              set:html={icons[s.icon]}
            />
          </div>
          <div>
            <h3 class="text-white font-semibold text-sm mb-1.5 leading-snug">{s.title}</h3>
            <p class="text-white/40 text-xs leading-relaxed">{s.label}</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
