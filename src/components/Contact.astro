---
const contactInfo = [
  {
    label: "WhatsApp",
    value: "096 697 977",
    href: "https://wa.me/598096697977",
    icon: `<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/>`,
  },
  {
    label: "Email",
    value: "contacto@verttex.net",
    href: "mailto:contacto@verttex.net",
    icon: `<rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>`,
  },
  {
    label: "Instagram",
    value: "@verttex.uy",
    href: "https://instagram.com/verttex.uy",
    icon: `<rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>`,
  },
];
---

<section id="contacto" class="bg-[#17120C] py-28 px-8 md:px-16">
  <div class="max-w-6xl mx-auto">

    <!-- Header -->
    <div class="mb-16">
      <span class="inline-flex items-center border border-[#B8864E]/40 text-[#B8864E] text-xs font-medium px-4 py-1.5 rounded-full mb-8 tracking-wide">
        Contacto
      </span>
      <h2 class="text-4xl md:text-6xl font-bold text-white leading-tight">
        Hablemos de<br />
        <span class="bg-gradient-to-r from-[#B8864E] via-[#D4A574] to-[#B8864E] bg-clip-text text-transparent">
          tu proyecto.
        </span>
      </h2>
      <p class="mt-5 text-white/45 text-base max-w-md leading-relaxed">
        Contanos qué necesitás y te respondemos en menos de 24 horas. Sin compromisos.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Info de contacto -->
      <div class="flex flex-col gap-4">
        {contactInfo.map((c) => (
          <a
            href={c.href}
            target="_blank"
            rel="noopener noreferrer"
            class="group flex items-center gap-5 bg-[#120E08] border border-white/[0.07] hover:border-[#B8864E]/30 rounded-2xl px-6 py-5 transition-all duration-300"
          >
            <div class="w-11 h-11 rounded-xl bg-[#B8864E]/10 group-hover:bg-[#B8864E]/20 flex items-center justify-center flex-shrink-0 transition-all duration-300">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#B8864E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={c.icon} />
            </div>
            <div>
              <p class="text-white/30 text-xs mb-0.5">{c.label}</p>
              <p class="text-white text-sm font-medium">{c.value}</p>
            </div>
            <span class="ml-auto text-white/20 group-hover:text-[#B8864E] transition-colors duration-300 text-sm">→</span>
          </a>
        ))}
      </div>

      <!-- Formulario -->
      <form id="contact-form" class="flex flex-col gap-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-2">
            <label class="text-white/40 text-xs">Nombre</label>
            <input
              type="text"
              name="name"
              id="input-name"
              placeholder="Juan García"
              required
              class="bg-[#120E08] border border-white/[0.07] focus:border-[#B8864E]/50 rounded-xl px-4 py-3 text-white text-sm placeholder:text-white/20 outline-none transition-colors duration-200"
            />
          </div>
          <div class="flex flex-col gap-2">
            <label class="text-white/40 text-xs">Email</label>
            <input
              type="email"
              name="email"
              id="input-email"
              placeholder="juan@empresa.com"
              required
              class="bg-[#120E08] border border-white/[0.07] focus:border-[#B8864E]/50 rounded-xl px-4 py-3 text-white text-sm placeholder:text-white/20 outline-none transition-colors duration-200"
            />
          </div>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-white/40 text-xs">¿En qué podemos ayudarte?</label>
          <select name="title" id="input-title" required class="bg-[#120E08] border border-white/[0.07] focus:border-[#B8864E]/50 rounded-xl px-4 py-3 text-white text-sm outline-none transition-colors duration-200 appearance-none cursor-pointer">
            <option value="" disabled selected class="text-white/20">Seleccioná un servicio</option>
            <option value="Página web">Página web</option>
            <option value="Sistema a medida">Sistema a medida</option>
            <option value="Automatización">Automatización</option>
            <option value="Agente de IA">Agente de IA</option>
            <option value="Aplicación móvil">Aplicación móvil</option>
            <option value="Marketing digital">Marketing digital</option>
            <option value="Otro">Otro</option>
          </select>
        </div>

        <div class="flex flex-col gap-2">
          <label class="text-white/40 text-xs">Mensaje</label>
          <textarea
            name="message"
            id="input-message"
            rows="4"
            required
            placeholder="Contanos un poco sobre tu proyecto..."
            class="bg-[#120E08] border border-white/[0.07] focus:border-[#B8864E]/50 rounded-xl px-4 py-3 text-white text-sm placeholder:text-white/20 outline-none transition-colors duration-200 resize-none"
          ></textarea>
        </div>

        <button
          id="submit-btn"
          type="submit"
          class="w-full bg-[#B8864E] hover:bg-[#D4A574] text-black font-semibold text-sm py-3.5 rounded-full transition-all duration-300 shadow-lg shadow-[#B8864E]/20 mt-2 disabled:opacity-50 disabled:cursor-not-allowed"
        >
          Enviar mensaje
        </button>

        <!-- Feedback -->
        <p id="form-success" class="hidden text-center text-sm text-green-400">¡Mensaje enviado! Te respondemos pronto.</p>
        <p id="form-error" class="hidden text-center text-sm text-red-400">Hubo un error al enviar. Intentá de nuevo.</p>
      </form>

    </div>
  </div>
</section>

<script>
  import emailjs from '@emailjs/browser';

  emailjs.init('KDgFmum2Hk0CObobq');

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn  = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success')!;
  const errorMsg   = document.getElementById('form-error')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.textContent = 'Enviando...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      await emailjs.sendForm('service_vuif9uj', 'template_8xv88yt', form);
      successMsg.classList.remove('hidden');
      form.reset();
    } catch {
      errorMsg.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Enviar mensaje';
    }
  });
</script>
